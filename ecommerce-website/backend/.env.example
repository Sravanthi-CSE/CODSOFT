# Backend Environment Variables
# Copy this file to .env and fill in your values

# Database Configuration
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/ecommerce
# For Local: mongodb://localhost:27017/ecommerce
MONGO_URI=mongodb://localhost:27017/ecommerce

# JWT Configuration (Generate a strong random string)
JWT_SECRET=your_jwt_secret_key_here_change_this_to_secure_value

# Admin Configuration
ADMIN_EMAIL=admin@shophub.com

# Email Configuration (Required for order confirmations)
# For Gmail: Use your Gmail address and app password
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Payment Gateway - Stripe (Optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Payment Gateway - Razorpay (Required for Indian payments)
# Get from: https://dashboard.razorpay.com/app/settings/api-keys
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Frontend Configuration
CLIENT_URL=http://localhost:5173

# Server Configuration
NODE_ENV=development
PORT=5000
